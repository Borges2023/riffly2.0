{
  "id": null,
  "uid": "riffly-backend-metrics",
  "title": "Riffly Backend Metrics",
  "version": 1,
  "schemaVersion": 37,
  "timezone": "browser",
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU Usage (seconds)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(process_cpu_user_seconds_total[1m]) + rate(process_cpu_system_seconds_total[1m])",
          "legendFormat": "CPU seconds/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS bytes",
          "refId": "A"
        },
        {
          "expr": "process_virtual_memory_bytes",
          "legendFormat": "Virtual bytes",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Node.js Heap Usage",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "Heap used",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_total_bytes",
          "legendFormat": "Heap total",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Event Loop Lag",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "Event loop lag",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Open Handles and Requests",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "nodejs_active_handles_total",
          "legendFormat": "Active handles",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_requests_total",
          "legendFormat": "Active requests",
          "refId": "B"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Process Uptime",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "options": {
        "unit": "s",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    }
  ],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m"]
  },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "tags": ["backend", "riffly"]
}
