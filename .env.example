# Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb://mongo:27017/riffly

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=sua_chave_super_secreta_aqui_altere_em_producao
JWT_REFRESH_SECRET=sua_chave_refresh_super_secreta_aqui_altere_em_producao

# CORS
CORS_ORIGIN=http://localhost:5173

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app

# OAuthGoogle
GOOGLE_CLIENT_ID=seu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_google_client_secret_aqui

# OAuth Facebook
FACEBOOK_APP_ID=seu_facebook_app_id_aqui
FACEBOOK_APP_SECRET=seu_facebook_app_secret_aqui

# Cloudinary (upload de imagens)
CLOUDINARY_NAME=seu_cloudinary_name
CLOUDINARY_API_KEY=seu_api_key
CLOUDINARY_API_SECRET=seu_api_secret
